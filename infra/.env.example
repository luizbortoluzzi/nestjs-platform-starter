# ─────────────────────────────────────────────────────────────────────────────
# Docker Compose environment — copy this file to infra/.env before running
# `docker compose up`. Values here are safe defaults for local development only.
#
# Key difference from apps/api/.env.example:
#   DATABASE_HOST and REDIS_HOST use Docker service names (postgres / redis),
#   not localhost, because all containers share the same Compose network.
#
# DO NOT commit infra/.env — it is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=6000
CORS_ORIGINS=http://localhost:6000

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
# Host must match the Compose service name — not localhost.
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=platform_db
DATABASE_USER=platform_user
DATABASE_PASSWORD=platform_pass
DATABASE_SSL=false
# true is acceptable locally — lets TypeORM sync the schema without migrations.
# Always false in staging / production.
DATABASE_SYNCHRONIZE=true
DATABASE_LOGGING=false

# ─── Redis ────────────────────────────────────────────────────────────────
# Host must match the Compose service name — not localhost.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# ─── JWT ──────────────────────────────────────────────────────────────────
# Replace with long random strings before deploying anywhere beyond localhost.
JWT_SECRET=dev-jwt-secret-replace-before-any-deployment
JWT_REFRESH_SECRET=dev-refresh-secret-replace-before-any-deployment
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
