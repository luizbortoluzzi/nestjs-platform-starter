# ─── Application ──────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3000

# ─── Database (PostgreSQL) ─────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=platform_db
DATABASE_USER=platform_user
DATABASE_PASSWORD=platform_pass
DATABASE_SSL=false
# IMPORTANT: keep false in production — use migrations only
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false

# ─── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Default TTL in seconds (1 hour)
REDIS_TTL=3600

# ─── JWT ──────────────────────────────────────────────────
# IMPORTANT: use different, strong random strings for each secret in production
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-use-a-different-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Development tip ──────────────────────────────────────
# Set DATABASE_SYNCHRONIZE=true locally to apply schema changes without
# running migrations. Always keep false in production.
# DATABASE_SYNCHRONIZE=true
