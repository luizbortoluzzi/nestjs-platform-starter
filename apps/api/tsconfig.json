{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,

    // ─── Type safety ──────────────────────────────────────────────────────
    // strictNullChecks: every value that might be null or undefined must be
    // handled explicitly. This is the single most valuable strict flag —
    // it catches a whole class of runtime crashes at compile time.
    "strictNullChecks": true,

    // noImplicitAny: left off intentionally. Enabling it produces errors
    // across third-party decorator metadata and Passport callback signatures
    // that are not worth the noise at this stage. Add explicit :any where
    // needed if you enable this in future.
    "noImplicitAny": false,

    // These are TypeScript defaults (true when unspecified) — listed
    // explicitly so they cannot accidentally regress via a config merge.
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true
  }
}
