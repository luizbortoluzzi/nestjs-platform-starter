{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,

    // ─── Type safety ──────────────────────────────────────────────────────
    // strict: true enables strictNullChecks, noImplicitAny, strictFunctionTypes,
    // strictBindCallApply, strictPropertyInitialization, and noImplicitThis.
    // strictPropertyInitialization is overridden below for TypeORM entities.
    "strict": true,

    // TypeORM entities declare columns as class properties without initialising
    // them in the constructor — the ORM handles hydration at runtime.
    // strictPropertyInitialization would flag every column as an error.
    "strictPropertyInitialization": false,

    // Catches functions that may return implicitly — forces explicit return on
    // every branch so callers can never receive an unexpected undefined.
    "noImplicitReturns": true,

    // Forces the `override` keyword on any method that overrides a base-class
    // method. Prevents silent breakage when the base class changes its API.
    "noImplicitOverride": true,

    // noUncheckedIndexedAccess: array[i] and obj[key] return T | undefined
    // rather than T. Catches a large class of off-by-one and missing-key bugs.
    "noUncheckedIndexedAccess": true,

    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true
  }
}
